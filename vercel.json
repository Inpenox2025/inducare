{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/api/auth?action=login" },
    { "source": "/api/auth/me", "destination": "/api/auth?action=me" },
    { "source": "/api/users/:id", "destination": "/api/users?id=:id" },
    { "source": "/api/doctors/:id", "destination": "/api/doctors?id=:id" },
    { "source": "/api/rooms/allocations/:id", "destination": "/api/rooms?action=allocation&id=:id" },
    { "source": "/api/rooms/allocations", "destination": "/api/rooms?action=allocation" },
    { "source": "/api/rooms/visits", "destination": "/api/rooms?action=visit" },
    { "source": "/api/rooms/:id", "destination": "/api/rooms?id=:id" },
    { "source": "/api/patients/:id", "destination": "/api/patients?id=:id" },
    { "source": "/api/appointments/:id", "destination": "/api/appointments?id=:id" },
    { "source": "/api/invoices/export-pdf", "destination": "/api/invoices?action=export-pdf" },
    { "source": "/api/invoices/export-receipt-pdf", "destination": "/api/invoices?action=export-receipt-pdf" },
    { "source": "/api/invoices/:id", "destination": "/api/invoices?id=:id" },
    { "source": "/api/super", "destination": "/api/super" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    }
  ]
}
